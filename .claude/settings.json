{
  "permissions": {
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"MANDATORY: Before acting on ANY request, you MUST fully read AGENTS.md then AGENTS.local.md (if it exists).\"}}'",
            "shell": "bash"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "nx@nx-claude-plugins": true,
    "context-mode@context-mode": true,
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": ["www.google-analytics.com"]
    }
  }
}
